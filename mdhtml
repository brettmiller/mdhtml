#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "markdown",
#   "pygments",
# ]
# ///

"""Serve local markdown files as rendered HTML in your browser."""

import argparse
import html
import http.server
import socket
import sys
import threading
import webbrowser
from pathlib import Path
from urllib.parse import quote, unquote

import markdown as _md
from pygments.formatters import HtmlFormatter
from pygments.styles import get_all_styles

_PYGMENTS_LIGHT = HtmlFormatter(style="perldoc").get_style_defs(".codehilite")  # may be replaced by --theme
_PYGMENTS_DARK_FORCED = HtmlFormatter(style="monokai").get_style_defs("html.dark .codehilite")
_PYGMENTS_DARK_MEDIA = HtmlFormatter(style="monokai").get_style_defs("html:not(.light) .codehilite")

_MD_EXTENSIONS = ["extra", "codehilite", "toc"]
_MD_CONFIGS = {
    "codehilite": {"guess_lang": True},
    "toc": {"permalink": False},
}

