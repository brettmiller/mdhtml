_TOGGLE_JS = """
(function () {
    var btn = document.getElementById('theme-toggle');
    var root = document.documentElement;

    function isDark() {
        if (root.classList.contains('dark')) return true;
        if (root.classList.contains('light')) return false;
        return window.matchMedia('(prefers-color-scheme: dark)').matches;
    }

    function update() {
        btn.textContent = isDark() ? '☀ Light' : '☾ Dark';
    }

    btn.addEventListener('click', function () {
        if (isDark()) {
            root.classList.remove('dark');
            root.classList.add('light');
        } else {
            root.classList.remove('light');
            root.classList.add('dark');
        }
        update();
    });

    update();
})();
"""


_forced_mode: str = ""  # "dark", "light", or ""
_OUTPUT_UNSET = object()


def _build_page(title: str, body: str, show_back: bool = False, back_href: str = "/") -> bytes:
    back = f'<nav class="back"><a href="{html.escape(back_href)}">← Index</a></nav>' if show_back else ""
    cls = f' class="{_forced_mode}"' if _forced_mode else ""
    return f"""<!DOCTYPE html>
<html lang="en"{cls}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{html.escape(title)}</title>
  <style>
{_PYGMENTS_LIGHT}
{_PYGMENTS_DARK_FORCED}
@media (prefers-color-scheme: dark) {{
{_PYGMENTS_DARK_MEDIA}
}}
{_PAGE_CSS}
  </style>
</head>
<body>
  <button id="theme-toggle"></button>
  <div class="container">
    {back}
    {body}
  </div>
  <script>{_TOGGLE_JS}</script>
</body>
</html>""".encode()


def _render(text: str) -> str:
    return _md.markdown(text, extensions=_MD_EXTENSIONS, extension_configs=_MD_CONFIGS)


def _display_name(stem: str) -> str:
    return stem.replace("-", " ").replace("_", " ").title()


class _Handler(http.server.BaseHTTPRequestHandler):
    files: dict[str, Path]
    single: bool

    def do_GET(self) -> None:
        path = unquote(self.path).lstrip("/").split("?")[0]

        if not path:
            if self.single:
                self._redirect(f"/{quote(next(iter(self.files)))}")
            else:
                self._serve_index()
        elif path in self.files:
            self._serve_md(path)
        else:
            self._respond(404, b"Not found")

    def _serve_index(self) -> None:
        items = "\n".join(
            f'<li><a href="/{quote(name)}">{html.escape(_display_name(fp.stem))}</a></li>'
            for name, fp in sorted(self.files.items())
        )
        body = f"<h1>Markdown Files</h1><ul class='index-list'>{items}</ul>"
        self._respond(200, _build_page("Index", body))

    def _serve_md(self, name: str) -> None:
        fp = self.files[name]
        body = _render(fp.read_text(encoding="utf-8"))
        self._respond(200, _build_page(_display_name(fp.stem), body, show_back=not self.single))

    def _redirect(self, location: str) -> None:
        self.send_response(302)
        self.send_header("Location", location)
        self.end_headers()

    def _respond(self, code: int, data: bytes) -> None:
        self.send_response(code)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def log_message(self, *_) -> None:
        pass


def _write_output(files: dict[str, Path], out_val: str | None, single: bool) -> None:
    first_src = next(iter(files.values()))

    exact_file: Path | None = None
    out_dir: Path | None = None

    if out_val is None:
        out_dir = first_src.parent
    else:
        out_path = Path(out_val).expanduser().resolve()
        if out_path.is_dir():
            out_dir = out_path
        elif not out_path.exists():
            if single and out_path.suffix:
                exact_file = out_path
            else:
                out_dir = out_path
                out_dir.mkdir(parents=True, exist_ok=True)
        elif out_path.is_file():
            if single:
                exact_file = out_path
            else:
                sys.exit(f"error: output path is an existing file, expected a directory: {out_path}")
        else:
            sys.exit(f"error: cannot use output path: {out_path}")

    if exact_file is not None:
        exact_file.parent.mkdir(parents=True, exist_ok=True)
        body = _render(first_src.read_text(encoding="utf-8"))
        exact_file.write_bytes(_build_page(_display_name(first_src.stem), body))
        print(f"→ {exact_file}")
        return

    assert out_dir is not None
    for fp in files.values():
        body = _render(fp.read_text(encoding="utf-8"))
        out_file = out_dir / (fp.stem + ".html")
        out_file.write_bytes(_build_page(_display_name(fp.stem), body, show_back=not single, back_href="./index.html"))
        print(f"→ {out_file}")

    if not single:
        items = "\n".join(
            f'<li><a href="./{html.escape(fp.stem)}.html">{html.escape(_display_name(fp.stem))}</a></li>'
            for fp in sorted(files.values(), key=lambda p: p.name)
        )
        body = f"<h1>Markdown Files</h1><ul class='index-list'>{items}</ul>"
        index_file = out_dir / "index.html"
        index_file.write_bytes(_build_page("Index", body))
        print(f"→ {index_file}")


def _free_port(start: int = 8080) -> int:
    for port in range(start, start + 100):
        with socket.socket() as s:
            if s.connect_ex(("127.0.0.1", port)) != 0:
                return port
    raise RuntimeError("No available port in range 8080–8179")


def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("path", nargs="?", default=".", help="Markdown file or directory (default: .)")
    mode = parser.add_mutually_exclusive_group()
    mode.add_argument("--dark", action="store_true", help="Force dark mode (default: system)")
    mode.add_argument("--light", action="store_true", help="Force light mode (default: system)")
    parser.add_argument(
        "--theme",
        metavar="NAME",
        help="Pygments syntax theme for both modes (default: perldoc / monokai). See --list-themes for options.",
    )
    parser.add_argument("--list-themes", action="store_true", help="List available Pygments syntax themes and exit")
    parser.add_argument(
        "-o", "--output",
        nargs="?",
        const=None,
        default=_OUTPUT_UNSET,
        metavar="PATH",
        help=(
            "Write HTML files instead of serving. "
            "PATH may be a directory or (for a single input file) an .html filename. "
            "Defaults to the source file's directory when omitted."
        ),
    )
    args = parser.parse_args()

    if args.list_themes:
        print("\n".join(sorted(get_all_styles())))
        return

    global _forced_mode, _PYGMENTS_LIGHT, _PYGMENTS_DARK_FORCED, _PYGMENTS_DARK_MEDIA
    if args.dark:
        _forced_mode = "dark"
    elif args.light:
        _forced_mode = "light"

    if args.theme:
        if args.theme not in get_all_styles():
            sys.exit(f"error: unknown theme '{args.theme}'. Run --list-themes for options.")
        _PYGMENTS_LIGHT = HtmlFormatter(style=args.theme).get_style_defs(".codehilite")
        _PYGMENTS_DARK_FORCED = HtmlFormatter(style=args.theme).get_style_defs("html.dark .codehilite")
        _PYGMENTS_DARK_MEDIA = HtmlFormatter(style=args.theme).get_style_defs("html:not(.light) .codehilite")

    target = Path(args.path).expanduser().resolve()

    if target.is_file():
        if target.suffix.lower() not in {".md", ".markdown"}:
            sys.exit(f"error: not a markdown file: {target}")
        files = {target.name: target}
    elif target.is_dir():
        found = sorted(
            f for f in target.iterdir()
            if f.is_file() and f.suffix.lower() in {".md", ".markdown"}
        )
        if not found:
            sys.exit(f"error: no markdown files found in {target}")
        files = {f.name: f for f in found}
    else:
        sys.exit(f"error: path not found: {target}")

    single = len(files) == 1

    if args.output is not _OUTPUT_UNSET:
        _write_output(files, args.output, single)
        return

    handler = type("Handler", (_Handler,), {"files": files, "single": single})

    port = _free_port()
    server = http.server.HTTPServer(("127.0.0.1", port), handler)

    base = f"http://127.0.0.1:{port}"
    url = f"{base}/{quote(next(iter(files)))}" if single else base
    print(f"→ {url}  (Ctrl-C to stop)")
    threading.Timer(0.3, webbrowser.open, args=[url]).start()

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print()


if __name__ == "__main__":
    main()
